-- ======================================================
--                  WORK IN PROGRESS
-- ======================================================

-- Stores physical warehouse/storage locations
CREATE TABLE deposit (
    id TEXT PRIMARY KEY,
    location TEXT,
    size TEXT, -- e.g., 'Small', 'Large'
    volume_actual REAL,
    volume_max REAL
);

-- Vehicle fleet data; tracks current status and physical load
CREATE TABLE truck (
    id TEXT PRIMARY KEY,
    model TEXT,
    size TEXT,
    volume_actual REAL,
    volume_max REAL,
    weight_actual REAL,
    weight_max REAL,
    estimated_time TEXT, -- ETA for current trip
    is_delivering INTEGER, -- Boolean (0/1)
    speed INTEGER,
    is_valid INTEGER, -- Maintenance status
    is_traveling INTEGER,
    current_location TEXT,
    origin TEXT,
    destination TEXT,
    deposit_id TEXT, -- Current home base or dock

    FOREIGN KEY (deposit_id) REFERENCES deposit(id)
);

-- Catalog of products; contains static dimensions and properties
CREATE TABLE product (
    id TEXT PRIMARY KEY,
    name TEXT,
    is_cold INTEGER, -- Boolean: Requires refrigeration
    is_fragile INTEGER,
    expire_date TEXT, -- Format: YYYY-MM-DD
    price REAL,
    size TEXT,
    volume REAL,
    weight REAL
);

-- Customer orders and delivery requirements
CREATE TABLE orders (
    id TEXT PRIMARY KEY,
    final_destination TEXT, -- Client adress
    sender TEXT,
    receiver TEXT,
    time_limit TEXT,
    price REAL,
    status TEXT, -- e.g., 'Pending', 'Shipped', 'Delivered'
    client_id TEXT,

    FOREIGN KEY (client_id) REFERENCES user(id),
    FOREIGN KEY (final_destination) REFERENCES user(adress) 
);

-- Inventory Tracking: Connects products to their physical location
-- Uses a XOR constraint to ensure an item is only in ONE place
CREATE TABLE stock (
    id TEXT PRIMARY KEY,
    product_id TEXT NOT NULL,
    quantity INTEGER NOT NULL CHECK (quantity >= 0),
    deposit_id TEXT,
    truck_id TEXT,
    order_id TEXT,
    arrived_at TEXT,

    FOREIGN KEY (product_id) REFERENCES product(id),
    FOREIGN KEY (deposit_id) REFERENCES deposit(id),
    FOREIGN KEY (truck_id) REFERENCES truck(id),
    FOREIGN KEY (order_id) REFERENCES orders(id),

    -- Ensures inventory cannot be in a truck and deposit simultaneously
    CHECK (
        (deposit_id IS NOT NULL AND truck_id IS NULL AND order_id IS NULL)
        OR
        (deposit_id IS NULL AND truck_id IS NOT NULL AND order_id IS NULL)
        OR
        (deposit_id IS NULL AND truck_id IS NULL AND order_id IS NOT NULL)
    ),

    UNIQUE(product_id, deposit_id, truck_id, order_id)
);

-- Tracking the journey of an order through various deposits
CREATE TABLE order_route (
    order_id TEXT,
    step INTEGER CHECK (step > 0), -- Sequence of the stop
    deposit_id TEXT,
    estimated_time TEXT,
    arrived_at TEXT,

    PRIMARY KEY (order_id, step),
    FOREIGN KEY (order_id) REFERENCES orders(id),
    FOREIGN KEY (deposit_id) REFERENCES deposit(id)
);

-- Staff assignments to either a warehouse or a vehicle
CREATE TABLE employee (
    id TEXT PRIMARY KEY,
    name TEXT,
    is_able INTEGER, -- Certification or health status
    deposit_id TEXT,
    truck_id TEXT,

    FOREIGN KEY (deposit_id) REFERENCES deposit(id),
    FOREIGN KEY (truck_id) REFERENCES truck(id),

    -- XOR constraint: Employee is assigned to a building OR a truck
    CHECK (
        (deposit_id IS NOT NULL AND truck_id IS NULL)
        OR
        (deposit_id IS NULL AND truck_id IS NOT NULL)
    )
);

-- System users including clients and potentially internal staff
CREATE TABLE user (
    id TEXT PRIMARY KEY,
    name TEXT,
    work_position TEXT,
    password TEXT,
    adress TEXT
);
