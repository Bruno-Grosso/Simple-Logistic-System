# Copy to `.env.local` (gitignored). Never commit real secrets.

# -----------------------------------------------------------------------------
# Session signing (required in production)
# -----------------------------------------------------------------------------
# Generate e.g. `openssl rand -base64 32`
AUTH_SECRET=

# -----------------------------------------------------------------------------
# Authentication — use one of these strategies
# -----------------------------------------------------------------------------

# Option A — Single user (simplest for small deployments)
LOGISYS_AUTH_EMAIL=
LOGISYS_AUTH_PASSWORD=

# Option B — External HTTP API (Drogon backend)
# Base URL for the C++ backend — all API calls are relative to this (e.g. POST /login, POST /clients).
# LOGISYS_BACKEND_URL=http://localhost:8848
#
# Login: POST /login  →  { "email", "password" }  →  { "ok": true, "token": "..." }
# Register: POST /clients  →  { "id", "name", "email", "password", "address", "role" }
#
# Optional: custom JSON key for the session token in the login response (default: "token")
# LOGISYS_BACKEND_TOKEN_FIELD=my_access_token
# Required for backend session validation: URL that accepts Bearer token → returns { "email": "..." }
# LOGISYS_BACKEND_SESSION_ME_URL=https://your-api.example.com/auth/me

# Option C — Local development only (do not set in production)
# LOGISYS_ALLOW_DEV_LOGIN=true
# LOGISYS_DEV_USERS_JSON=[{"email":"user@example.com","password":"at-least-8-chars"}]
